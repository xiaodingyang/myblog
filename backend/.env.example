# 服务端口
PORT=3000

# 运行环境: development | production
NODE_ENV=development

# MongoDB 连接地址
MONGODB_URI=mongodb://localhost:27017/blog

# JWT 密钥（生产环境请务必修改为强随机字符串）
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRES_IN=7d

# 前端地址（生产环境 CORS；可逗号分隔多个）。须与浏览器地址栏「协议+主机+端口」一致。
# 两段式主域（如 example.com）会在服务端自动补齐 www ⇄ 裸域；仍建议显式写出常用入口。
# GitHub OAuth 回调会按请求 Host 在该列表中匹配；未匹配时用第一项。
FRONTEND_URL=http://localhost:8001

# GitHub OAuth（可选，用于用户登录）
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# 生产环境回调域名会并入 CORS 白名单推导（与 FRONTEND_URL 二选一至少配其一即可）
GITHUB_CALLBACK_URL=http://localhost:3000/api/github/callback

# ── 站内 AI 答疑（OpenAI 兼容 Chat Completions，密钥勿提交仓库）──
# 与本机 ~/.claude/providers.json 中 profile「vb」对应示例：
#   baseUrl → AI_API_BASE   例：https://cc-vibe.com
#   key     → AI_API_KEY    （仅写在 .env，勿提交）
#   model   → AI_CHAT_MODEL 例：claude-opus-4-6（成本高，可按网关价目换轻量模型）
# AI_API_BASE=https://cc-vibe.com
# AI_API_KEY=
# AI_CHAT_MODEL=gpt-4o-mini
# AI_MAX_QUESTION_CHARS=800
# AI_RETRIEVAL_TOP_K=6
# AI_RETRIEVAL_MIN_SCORE=1
# 同分类扩展检索（AI_CATEGORY_ASSIST=0 关闭整类能力）
# AI_CATEGORY_ASSIST=1
# AI_CATEGORY_MAX_DOCS=8
# 本篇无强命中时，同分类最多纳入条数
# AI_CATEGORY_CHUNKS_TOTAL=6
# 本篇有命中时默认并入少量同分类摘录（=0 关闭；请求 body categoryAssist=true 可强制开启）
# AI_CATEGORY_MERGE_WITH_ARTICLE=1
# AI_CATEGORY_CHUNKS_MERGED=4
# 无摘录时仍调模型通用作答（一般保持默认即可）
# AI_ASK_HOURLY_LIMIT_IP_ANON=5
# AI_ASK_HOURLY_LIMIT_USER=20
# AI_UPSTREAM_TIMEOUT_MS=90000

# ── AI 新闻推送（NewsAPI）──
# 注册地址: https://newsapi.org/
# 免费额度: 每天 100 次请求
# NEWSAPI_KEY=your_newsapi_key

# 经 Nginx/CDN 反代时设为 1，便于 IP 限流识别真实客户端
# TRUST_PROXY=1
