# 测试环境配置
# 复制此文件为 .env.local 并修改配置

# 测试目标：local（本地）或 production（线上）
TEST_TARGET=production

# 本地环境配置
LOCAL_BASE_URL=http://127.0.0.1:8001
LOCAL_API_URL=http://127.0.0.1:3000

# 线上环境配置
PRODUCTION_BASE_URL=https://www.xiaodingyang.art
PRODUCTION_API_URL=https://www.xiaodingyang.art

# 测试账号（用于后台 / 可视化 E2E；需与本地 Mongo 中用户一致）
TEST_ADMIN_USERNAME=ruofeng
TEST_ADMIN_PASSWORD=123456

# Mock 模式：true 时使用 mock 数据，false 时使用真实 API
USE_MOCK_API=false

# 截图对比容差
SCREENSHOT_MAX_DIFF_PIXELS=100000
SCREENSHOT_MAX_DIFF_RATIO=0.10

# 超时配置（毫秒）
TEST_TIMEOUT=120000
EXPECT_TIMEOUT=30000
