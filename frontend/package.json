{
  "name": "blog-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "个人博客前端 - Umi 4 + Ant Design 5 + Tailwind CSS",
  "scripts": {
    "dev": "cross-env PORT=8080 umi dev",
    "dev:strict": "node scripts/dev-strict.mjs",
    "e2e": "node scripts/run-e2e.mjs",
    "e2e:visual": "node scripts/run-visual-batches.mjs",
    "e2e:visual:public": "cross-env PLAYWRIGHT_VISUAL_BATCH=public pnpm exec playwright test",
    "e2e:visual:admin": "cross-env PLAYWRIGHT_VISUAL_BATCH=admin pnpm exec playwright test --workers=1",
    "lhci": "node scripts/run-lhci.mjs",
    "build": "umi build",
    "build:ssg": "umi build && umi generate",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx src --fix"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/icons": "^5.6.1",
    "@sentry/react": "^10.47.0",
    "@tanstack/react-query": "^5.96.2",
    "@tsparticles/react": "3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@xdy-npm/react-particle-backgrounds": "1.4.0",
    "@xdy-npm/realtime-rss-hub-react": "^0.1.0",
    "antd": "^5.29.3",
    "antd-img-crop": "^4.30.0",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^9.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "umi": "^4.6.34"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.55.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@umijs/plugins": "^4.6.34",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.5"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
